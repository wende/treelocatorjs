{
  "name": "@treelocator/extension",
  "private": true,
  "version": "0.1.0",
  "description": "TreeLocatorJS Chrome extension for local development component ancestry inspection.",
  "scripts": {
    "build": "node ./scripts/build.js",
    "dev": "node ./scripts/dev.js",
    "pack:chrome": "cd ./build/production_chrome && rm -f ../treelocatorjs-chrome.zip && zip -r ../treelocatorjs-chrome.zip ."
  },
  "dependencies": {
    "@treelocator/runtime": "workspace:^"
  },
  "devDependencies": {
    "@babel/core": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "babel-loader": "9.1.2",
    "babel-preset-solid": "1.9.9",
    "fs-extra": "11.3.2",
    "typescript": "5.9.3",
    "webpack": "5.102.1"
  }
}
